  <!-- ================= Blast doors (Machining) ================= -->
  <!-- Decorative frames/async leaves are a later milestone. These ship as sliding doors. -->

  <ThingDef ParentName="DExDoorBase">
    <defName>PH_DoorBlastSingle</defName>
    <label>blast door (1x1)</label>
    <description>A heavy door that is far more resilient to damage.</description>
    <!-- Remote-class door (stub until M2), matching the original and old saves. Draws via
         the expanded base: two mini leaves sliding inside the static frame housing. -->
    <thingClass>DoorsExpanded.Building_DoorRemote</thingClass>
    <size>(1,1)</size>
    <rotatable>false</rotatable>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <useBlueprintGraphicAsGhost>true</useBlueprintGraphicAsGhost>
    <statBases>
      <WorkToBuild>2000</WorkToBuild>
      <MaxHitPoints>500</MaxHitPoints>
      <Flammability>0.5</Flammability>
      <!-- 80% of a vanilla door's speed when powered (45/0.8 * 0.25 = 14.06 ticks); 20% unpowered. -->
      <DoorOpenSpeed>0.8</DoorOpenSpeed>
    </statBases>
    <costStuffCount>75</costStuffCount>
    <costList>
      <Steel>40</Steel>
      <ComponentIndustrial>4</ComponentIndustrial>
    </costList>
    <stuffCategories Inherit="False">
      <li>Metallic</li>
    </stuffCategories>
    <graphicData>
      <texPath>Things/Building/DEx/Door/DoorBlastDoor_MoverSingle</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
      <damageData>
        <enabled>false</enabled>
      </damageData>
    </graphicData>
    <uiIconPath>Things/Building/DEx/Door/BlastDoorSingleUI</uiIconPath>
    <building>
      <isStuffableAirtight>true</isStuffableAirtight>
      <blueprintClass>Blueprint_Build</blueprintClass>
      <blueprintGraphicData>
        <texPath>Things/Building/DEx/Door/DoorBlastDoorSingle</texPath>
        <graphicClass>Graphic_Single</graphicClass>
        <drawSize>(1,1)</drawSize>
      </blueprintGraphicData>
      <soundDoorOpenManual>DEx_BlastDoorOpen</soundDoorOpenManual>
      <soundDoorCloseManual>DEx_BlastDoorClose</soundDoorCloseManual>
      <!-- Heavy hydraulic doors: normal speed on power, ~4x slower without it. -->
      <unpoweredDoorOpenSpeedFactor>4.0</unpoweredDoorOpenSpeedFactor>
      <unpoweredDoorCloseSpeedFactor>4.0</unpoweredDoorCloseSpeedFactor>
    </building>
    <comps>
      <li Class="DoorsExpanded.CompProperties_DoorExpanded">
        <doorType>Standard</doorType>
        <rotatesSouth>false</rotatesSouth>
        <remoteDoor>true</remoteDoor>
        <doorFrame>
          <texPath>Things/Building/DEx/Door/DoorBlastDoorSingle</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <shaderType>CutoutComplex</shaderType>
          <drawSize>(1,1)</drawSize>
          <damageData><enabled>false</enabled></damageData>
        </doorFrame>
      </li>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>50</basePowerConsumption>
      </li>
      <li Class="CompProperties_Breakdownable"/>
    </comps>
    <researchPrerequisites>
      <li>Machining</li>
    </researchPrerequisites>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
  </ThingDef>

