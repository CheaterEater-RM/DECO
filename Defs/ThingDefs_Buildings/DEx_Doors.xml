  <!-- ================= Curtains (cloth, no research, NOT minifiable - they're doors) ================= -->

  <ThingDef ParentName="DExDoorBase">
    <defName>HeronCurtainTribal</defName>
    <label>curtain</label>
    <description>Divides rooms. Curtains open much faster than standard doors, but are flammable and offer no airtight seal.</description>
    <!-- Curtains refund their full build cost on deconstruction (vanilla doors default to 0.5). -->
    <resourcesFractionWhenDeconstructed>1.0</resourcesFractionWhenDeconstructed>
    <!-- Expanded class for the Stretch animation: a single sheet that bunches to one side.
         Vanilla Building_Door would draw the full-width sheet twice, sliding apart. -->
    <thingClass>DoorsExpanded.Building_DoorExpanded</thingClass>
    <size>(1,1)</size>
    <rotatable>false</rotatable>
    <statBases>
      <WorkToBuild>850</WorkToBuild>
      <MaxHitPoints>50</MaxHitPoints>
      <DoorOpenSpeed>4.0</DoorOpenSpeed>
      <Beauty>1</Beauty>
      <Flammability>1.0</Flammability>
    </statBases>
    <costStuffCount>25</costStuffCount>
    <stuffCategories Inherit="False">
      <li>Fabric</li>
      <li>Leathery</li>
    </stuffCategories>
    <graphicData>
      <texPath>Things/Building/DEx/Door/Curtain_Mover</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
      <damageData>
        <enabled>false</enabled>
      </damageData>
    </graphicData>
    <uiIconPath>Things/Building/DEx/Door/Curtain_Mover</uiIconPath>
    <building>
      <isStuffableAirtight>false</isStuffableAirtight>
      <roamerCanOpen>true</roamerCanOpen>
      <soundDoorOpenManual>DEx_CurtainOpen</soundDoorOpenManual>
      <soundDoorCloseManual>DEx_CurtainClose</soundDoorCloseManual>
      <alwaysExchangeVacuum>true</alwaysExchangeVacuum>
    </building>
    <comps>
      <li Class="DoorsExpanded.CompProperties_DoorExpanded">
        <doorType>Stretch</doorType>
        <singleDoor>true</singleDoor>
      </li>
    </comps>
  </ThingDef>

