  <!-- ================= Jail door (Smithing) ================= -->

  <ThingDef ParentName="DExDoorBase">
    <defName>PH_DoorJail</defName>
    <label>jail door</label>
    <description>A sliding jail cell door with strong bars.</description>
    <!-- Expanded class with the original's config (single panel, 0.8 travel) — also what
         old saves recorded for this door. -->
    <thingClass>DoorsExpanded.Building_DoorExpanded</thingClass>
    <size>(1,1)</size>
    <rotatable>false</rotatable>
    <!-- It's bars: shots pass through (Partial fillage) and it gives ~25% cover in vanilla
         combat. holdsRoof kept true so the door still supports roofs despite the low fill.
         Under Combat Extended the bars effect comes from CombatExtendedCompat instead. -->
    <fillPercent>0.25</fillPercent>
    <holdsRoof>true</holdsRoof>
    <statBases>
      <WorkToBuild>1500</WorkToBuild>
      <MaxHitPoints>300</MaxHitPoints>
    </statBases>
    <costStuffCount>50</costStuffCount>
    <costList>
      <Steel>30</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <stuffCategories Inherit="False">
      <li>Metallic</li>
    </stuffCategories>
    <graphicData>
      <texPath>Things/Building/DEx/Door/JailCell_Mover</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(1,1)</drawSize>
      <damageData>
        <enabled>false</enabled>
      </damageData>
    </graphicData>
    <uiIconPath>Things/Building/DEx/Door/JailCell_Mover</uiIconPath>
    <building>
      <!-- Not airtight: bars let air through (and isStuffableAirtight with non-Full Fillage
           is a vanilla ConfigError anyway). Near-instant temperature equalize even when
           closed, so a closed jail cell tracks the adjacent room like an open passage. -->
      <doorTempEqualizeIntervalClosed>34</doorTempEqualizeIntervalClosed>
      <doorTempEqualizeRate>1.0</doorTempEqualizeRate>
      <blueprintClass>Blueprint_Build</blueprintClass>
      <blueprintGraphicData>
        <texPath>Things/Building/DEx/Door/JailCell_Blueprint</texPath>
        <graphicClass>Graphic_Single</graphicClass>
        <drawSize>(1,1)</drawSize>
      </blueprintGraphicData>
      <soundDoorOpenManual>DEx_JailDoorOpen</soundDoorOpenManual>
      <soundDoorCloseManual>DEx_JailDoorClose</soundDoorCloseManual>
    </building>
    <comps>
      <li Class="DoorsExpanded.CompProperties_DoorExpanded">
        <doorType>Standard</doorType>
        <singleDoor>true</singleDoor>
        <doorOpenMultiplier>0.8</doorOpenMultiplier>
        <rotatesSouth>false</rotatesSouth>
      </li>
    </comps>
    <researchPrerequisites>
      <li>Smithing</li>
    </researchPrerequisites>
  </ThingDef>

