<?xml version="1.0" encoding="utf-8"?>
<ModMetaData>
  <name>DECO: Doors Expanded Continued Overhaul</name>
  <author>CheaterEater</author>
  <packageId>CheaterEater.DECO</packageId>
  <supportedVersions>
    <li>1.6</li>
  </supportedVersions>
  <description>Ground-up rewrite of Doors Expanded focused on bug fixes, QoL enhancements, maintainability and performance improvements.</description>
  <modVersion>1.1</modVersion>
  <url>https://github.com/CheaterEater-RM/DECO</url>

  <modDependencies>
    <li>
      <packageId>brrainz.harmony</packageId>
      <displayName>Harmony</displayName>
      <steamWorkshopUrl>steam://url/CommunityFilePage/2009463077</steamWorkshopUrl>
    </li>
  </modDependencies>

  <loadAfter>
    <li>brrainz.harmony</li>
    <li>Ludeon.RimWorld</li>
    <li>Ludeon.RimWorld.Royalty</li>
    <li>Ludeon.RimWorld.Ideology</li>
    <li>Ludeon.RimWorld.Biotech</li>
    <li>Ludeon.RimWorld.Anomaly</li>
    <li>Ludeon.RimWorld.Odyssey</li>
  </loadAfter>

  <!-- DECO owns the original Doors Expanded's internal names so saves swap freely between
       the two mods. Loading both at once duplicates those names and breaks. -->
  <incompatibleWith>
    <li>jecrell.doorsexpanded</li>
  </incompatibleWith>
</ModMetaData>
